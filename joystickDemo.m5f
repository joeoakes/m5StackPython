from m5stack import *
from m5ui import *
from uiflow import *
import unit

setScreenColor(0x000000)

joystick = unit.get(unit.JOYSTICK, unit.PORTA)

label = M5TextBox(10, 20, "", lcd.FONT_Default, 0xFFFFFF)

while True:
    x = joystick.X
    y = joystick.Y

    label.setText("X:{}  Y:{}".format(x, y))

    wait_ms(100)
